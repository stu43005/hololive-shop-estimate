# Estimator King - Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Load into your shell before running:
#   set -a; source .env; set +a
#
# See docs/local-runbook.md for full instructions.

# ── Crawler ──────────────────────────────────────────────────
# Dify API base URL
DIFY_BASE_URL=https://dify.long-cod.ts.net/v1

# Dify dataset API key (format: dataset-xxxx)
DIFY_API_KEY=

# Dify dataset UUID
DIFY_DATASET_ID=

# SQLite database path (default: ./estimator_king.db)
DATABASE_PATH=./estimator_king.db

# ── Discord Bot ──────────────────────────────────────────────
# Discord bot token (from Discord Developer Portal)
DISCORD_BOT_TOKEN=

# Dify workflow API key for /estimate command (format: app-xxxx)
DIFY_WORKFLOW_API_KEY=
