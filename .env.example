# Estimator King environment variables.
# Copy to .env and fill in:  cp .env.example .env
# The app does NOT auto-load .env — load it first:  set -a; source .env; set +a
# Commented lines show the default; uncomment to override.

# ── Provider base (OpenAI default) ──
# Point any *_BASE_URL at ollama's /v1 (etc.) to swap providers.
# EMBEDDING_/CHAT_/TYPING_ keys & base URLs fall back to these when unset.
OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1

# ── Embeddings ──
# EMBEDDING_API_KEY=            # falls back to OPENAI_API_KEY
# EMBEDDING_BASE_URL=           # falls back to OPENAI_BASE_URL
# EMBEDDING_MODEL=text-embedding-3-large
# EMBEDDING_DIMENSIONS=1024     # blank = provider default
# EMBEDDING_MAX_TOKENS=8192     # truncate each input to this many tokens (8192 for text-embedding-3-*)
# EMBEDDING_QUERY_PREFIX=       # prepended to query text (for models that need an instruction prefix)
# EMBEDDING_DOC_PREFIX=         # prepended to document text

# ── Chat (price estimation) ──
# CHAT_API_KEY=                 # falls back to OPENAI_API_KEY
# CHAT_BASE_URL=                # falls back to OPENAI_BASE_URL
# CHAT_MODEL=gpt-4o
# CHAT_STRUCTURED_OUTPUT=true   # set false for endpoints without strict schema support (e.g. ollama)

# ── Item-type classifier (small/cheap model) ──
# TYPING_MODEL=gpt-4o-mini
# TYPING_API_KEY=               # falls back to CHAT_API_KEY, then OPENAI_API_KEY
# TYPING_BASE_URL=              # falls back to CHAT_BASE_URL, then OPENAI_BASE_URL

# ── Storage ──
DATABASE_PATH=./estimator_king.db
CHROMA_PATH=./chroma

# ── Discord bot ──
DISCORD_BOT_TOKEN=
# DISCORD_TOKEN=                # alias; DISCORD_TOKEN takes precedence over DISCORD_BOT_TOKEN if both set

# ── Config file ──
# CONFIG_PATH=./stores_config.yaml   # overridden by the --config CLI flag

# ── Proxy (optional; only used when proxy.enabled=true in stores_config.yaml) ──
# HTTP_PROXY=
# HTTPS_PROXY=
